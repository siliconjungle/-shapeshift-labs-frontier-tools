{
  "name": "@shapeshift-labs/frontier-tools",
  "version": "0.1.0",
  "description": "Serializable action and tool manifests for agent-operable Frontier apps.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/siliconjungle/-shapeshift-labs-frontier-tools.git"
  },
  "homepage": "https://github.com/siliconjungle/-shapeshift-labs-frontier-tools#readme",
  "bugs": {
    "url": "https://github.com/siliconjungle/-shapeshift-labs-frontier-tools/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "benchmarks/package-bench.mjs",
    "benchmarks/competitor-bench.mjs"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.mjs",
    "test": "npm run build && npm run typecheck && node test/smoke.mjs && node test/fuzz.mjs --cases 900",
    "prepack": "npm run readme:packages:check && npm run test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p test/tsconfig.json --noEmit",
    "fuzz": "npm run build && node test/fuzz.mjs",
    "bench": "npm run build && node --expose-gc benchmarks/package-bench.mjs --out benchmarks/results/frontier-tools-package-bench-latest.json",
    "bench:competitors": "npm run build && node --expose-gc benchmarks/competitor-bench.mjs --out benchmarks/results/frontier-tools-competitors-latest.json",
    "pack:dry": "npm pack --dry-run",
    "readme:packages": "node benchmarks/package-readme-sections.mjs",
    "readme:packages:check": "node benchmarks/package-readme-sections.mjs --check"
  },
  "keywords": [
    "frontier",
    "tools",
    "agents",
    "actions",
    "function-calling",
    "mcp",
    "automation",
    "patches"
  ],
  "dependencies": {
    "@shapeshift-labs/frontier": "0.1.9"
  },
  "devDependencies": {
    "@langchain/core": "^1.1.48",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.193",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
